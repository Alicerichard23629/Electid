;; Public Transparency System for Electid\n;; Enables citizen petitions, transparency tracking, and public accountability\n\n(define-constant ERR_UNAUTHORIZED (err u300))\n(define-constant ERR_PETITION_NOT_FOUND (err u301))\n(define-constant ERR_INVALID_PETITION (err u302))\n(define-constant ERR_PETITION_CLOSED (err u303))\n(define-constant ERR_ALREADY_SIGNED (err u304))\n(define-constant ERR_OFFICIAL_NOT_FOUND (err u305))\n(define-constant ERR_INVALID_SIGNATURE_COUNT (err u306))\n(define-constant ERR_INVALID_RESPONSE (err u307))\n(define-constant ERR_RESPONSE_EXISTS (err u308))\n\n;; Petition categories and response requirements\n(define-constant MIN_SIGNATURES_LOCAL u100)\n(define-constant MIN_SIGNATURES_STATE u1000)\n(define-constant MIN_SIGNATURES_FEDERAL u10000)\n(define-constant RESPONSE_DEADLINE_BLOCKS u1440) ;; ~10 days\n\n(define-data-var petition-counter uint u0)\n(define-data-var transparency-report-counter uint u0)\n\n;; Citizen petitions for government transparency\n(define-map citizen-petitions\n  { petition-id: uint }\n  {\n    title: (string-ascii 128),\n    description: (string-ascii 512),\n    category: (string-ascii 32),\n    target-jurisdiction: (string-ascii 64),\n    target-officials: (list 10 uint),\n    created-by: principal,\n    created-at: uint,\n    signature-goal: uint,\n    current-signatures: uint,\n    deadline: uint,\n    status: (string-ascii 20),\n    response-required: bool,\n    response-deadline: (optional uint)\n  }\n)\n\n;; Track citizen signatures on petitions\n(define-map petition-signatures\n  { petition-id: uint, signature-id: uint }\n  {\n    signer: principal,\n    signed-at: uint,\n    signer-jurisdiction: (string-ascii 64),\n    verification-status: (string-ascii 20)\n  }\n)\n\n;; Official responses to petitions\n(define-map petition-responses\n  { petition-id: uint, responder-token-id: uint }\n  {\n    response-text: (string-ascii 512),\n    response-type: (string-ascii 32),\n    responded-at: uint,\n    public-commitment: (optional (string-ascii 256)),\n    follow-up-deadline: (optional uint)\n  }\n)\n\n;; Transparency metrics for officials\n(define-map official-transparency-metrics\n  { token-id: uint }\n  {\n    total-petitions-received: uint,\n    petitions-responded: uint,\n    average-response-time: uint,\n    public-commitments-made: uint,\n    commitments-fulfilled: uint,\n    citizen-satisfaction-score: uint,\n    last-updated: uint\n  }\n)\n\n;; Public information requests\n(define-map information-requests\n  { request-id: uint }\n  {\n    requester: principal,\n    target-jurisdiction: (string-ascii 64),\n    request-type: (string-ascii 32),\n    description: (string-ascii 256),\n    created-at: uint,\n    response-deadline: uint,\n    status: (string-ascii 20),\n    fulfilled-at: (optional uint)\n  }\n)\n\n;; Transparency report summaries\n(define-map transparency-reports\n  { report-id: uint }\n  {\n    reporting-period: uint,\n    jurisdiction: (string-ascii 64),\n    total-officials: uint,\n    responsive-officials: uint,\n    average-response-rate: uint,\n    total-petitions: uint,\n    total-signatures: uint,\n    generated-at: uint,\n    published-by: principal\n  }\n)\n\n(define-data-var signature-counter uint u0)\n(define-data-var request-counter uint u0)\n\n;; Create a new citizen petition\n(define-public (create-petition\n  (title (string-ascii 128))\n  (description (string-ascii 512))\n  (category (string-ascii 32))\n  (target-jurisdiction (string-ascii 64))\n  (target-officials (list 10 uint))\n  (signature-goal uint)\n  (deadline-blocks uint))\n  (let\n    (\n      (petition-id (+ (var-get petition-counter) u1))\n      (current-time stacks-block-height)\n      (petition-deadline (+ current-time deadline-blocks))\n      (min-signatures (get-minimum-signatures target-jurisdiction))\n    )\n    (asserts! (>= signature-goal min-signatures) ERR_INVALID_SIGNATURE_COUNT)\n    (asserts! (> deadline-blocks u144) ERR_INVALID_PETITION) ;; At least 1 day\n    (asserts! (> (len target-officials) u0) ERR_INVALID_PETITION)\n    \n    (map-set citizen-petitions\n      { petition-id: petition-id }\n      {\n        title: title,\n        description: description,\n        category: category,\n        target-jurisdiction: target-jurisdiction,\n        target-officials: target-officials,\n        created-by: tx-sender,\n        created-at: current-time,\n        signature-goal: signature-goal,\n        current-signatures: u0,\n        deadline: petition-deadline,\n        status: "ACTIVE",\n        response-required: (>= signature-goal (* min-signatures u2)),\n        response-deadline: (if (>= signature-goal (* min-signatures u2)) \n                           (some (+ petition-deadline RESPONSE_DEADLINE_BLOCKS)) \n                           none)\n      }\n    )\n    \n    (var-set petition-counter petition-id)\n    (ok petition-id)\n  )\n)\n\n;; Sign a petition as a citizen\n(define-public (sign-petition (petition-id uint) (signer-jurisdiction (string-ascii 64)))\n  (let\n    (\n      (petition (unwrap! (map-get? citizen-petitions { petition-id: petition-id }) ERR_PETITION_NOT_FOUND))\n      (signature-id (+ (var-get signature-counter) u1))\n      (current-time stacks-block-height)\n    )\n    (asserts! (is-eq (get status petition) "ACTIVE") ERR_PETITION_CLOSED)\n    (asserts! (< current-time (get deadline petition)) ERR_PETITION_CLOSED)\n    (asserts! (not (has-signed-petition tx-sender petition-id)) ERR_ALREADY_SIGNED)\n    \n    ;; Record the signature\n    (map-set petition-signatures\n      { petition-id: petition-id, signature-id: signature-id }\n      {\n        signer: tx-sender,\n        signed-at: current-time,\n        signer-jurisdiction: signer-jurisdiction,\n        verification-status: "VERIFIED"\n      }\n    )\n    \n    ;; Update petition signature count\n    (let ((new-signature-count (+ (get current-signatures petition) u1)))\n      (map-set citizen-petitions\n        { petition-id: petition-id }\n        (merge petition {\n          current-signatures: new-signature-count,\n          status: (if (>= new-signature-count (get signature-goal petition)) "GOAL_REACHED" "ACTIVE")\n        })\n      )\n    )\n    \n    (var-set signature-counter signature-id)\n    (ok signature-id)\n  )\n)\n\n;; Official responds to a petition\n(define-public (respond-to-petition\n  (petition-id uint)\n  (responder-token-id uint)\n  (response-text (string-ascii 512))\n  (response-type (string-ascii 32))\n  (public-commitment (optional (string-ascii 256))))\n  (let\n    (\n      (petition (unwrap! (map-get? citizen-petitions { petition-id: petition-id }) ERR_PETITION_NOT_FOUND))\n      (current-time stacks-block-height)\n    )\n    ;; Verify official is target of petition\n    (asserts! (is-some (index-of (get target-officials petition) responder-token-id)) ERR_UNAUTHORIZED)\n    (asserts! (is-none (map-get? petition-responses { petition-id: petition-id, responder-token-id: responder-token-id })) ERR_RESPONSE_EXISTS)\n    \n    ;; Record the response\n    (map-set petition-responses\n      { petition-id: petition-id, responder-token-id: responder-token-id }\n      {\n        response-text: response-text,\n        response-type: response-type,\n        responded-at: current-time,\n        public-commitment: public-commitment,\n        follow-up-deadline: (if (is-some public-commitment) \n                            (some (+ current-time u2880)) ;; 20 days for follow-up\n                            none)\n      }\n    )\n    \n    ;; Update official's transparency metrics\n    (update-official-metrics responder-token-id petition current-time)\n    (ok true)\n  )\n)\n\n;; Submit public information request\n(define-public (request-information\n  (target-jurisdiction (string-ascii 64))\n  (request-type (string-ascii 32))\n  (description (string-ascii 256)))\n  (let\n    (\n      (request-id (+ (var-get request-counter) u1))\n      (current-time stacks-block-height)\n      (response-deadline (+ current-time u720)) ;; 5 days\n    )\n    (map-set information-requests\n      { request-id: request-id }\n      {\n        requester: tx-sender,\n        target-jurisdiction: target-jurisdiction,\n        request-type: request-type,\n        description: description,\n        created-at: current-time,\n        response-deadline: response-deadline,\n        status: "PENDING",\n        fulfilled-at: none\n      }\n    )\n    \n    (var-set request-counter request-id)\n    (ok request-id)\n  )\n)\n\n;; Generate transparency report for jurisdiction\n(define-public (generate-transparency-report (jurisdiction (string-ascii 64)))\n  (let\n    (\n      (report-id (+ (var-get transparency-report-counter) u1))\n      (current-time stacks-block-height)\n      (report-data (calculate-transparency-metrics jurisdiction))\n    )\n    (map-set transparency-reports\n      { report-id: report-id }\n      {\n        reporting-period: current-time,\n        jurisdiction: jurisdiction,\n        total-officials: (get total-officials report-data),\n        responsive-officials: (get responsive-officials report-data),\n        average-response-rate: (get average-response-rate report-data),\n        total-petitions: (get total-petitions report-data),\n        total-signatures: (get total-signatures report-data),\n        generated-at: current-time,\n        published-by: tx-sender\n      }\n    )\n    \n    (var-set transparency-report-counter report-id)\n    (ok report-id)\n  )\n)\n\n;; Read-only functions\n(define-read-only (get-petition (petition-id uint))\n  (map-get? citizen-petitions { petition-id: petition-id })\n)\n\n(define-read-only (get-petition-signatures (petition-id uint) (signature-id uint))\n  (map-get? petition-signatures { petition-id: petition-id, signature-id: signature-id })\n)\n\n(define-read-only (get-official-response (petition-id uint) (responder-token-id uint))\n  (map-get? petition-responses { petition-id: petition-id, responder-token-id: responder-token-id })\n)\n\n(define-read-only (get-official-metrics (token-id uint))\n  (default-to\n    {\n      total-petitions-received: u0,\n      petitions-responded: u0,\n      average-response-time: u0,\n      public-commitments-made: u0,\n      commitments-fulfilled: u0,\n      citizen-satisfaction-score: u0,\n      last-updated: u0\n    }\n    (map-get? official-transparency-metrics { token-id: token-id })\n  )\n)\n\n(define-read-only (get-information-request (request-id uint))\n  (map-get? information-requests { request-id: request-id })\n)\n\n(define-read-only (get-transparency-report (report-id uint))\n  (map-get? transparency-reports { report-id: report-id })\n)\n\n(define-read-only (has-petition-reached-goal (petition-id uint))\n  (match (map-get? citizen-petitions { petition-id: petition-id })\n    petition (>= (get current-signatures petition) (get signature-goal petition))\n    false\n  )\n)\n\n(define-read-only (get-official-responsiveness-score (token-id uint))\n  (let\n    (\n      (metrics (get-official-metrics token-id))\n      (total-petitions (get total-petitions-received metrics))\n      (responded-petitions (get petitions-responded metrics))\n    )\n    (if (> total-petitions u0)\n      (/ (* responded-petitions u100) total-petitions)\n      u100\n    )\n  )\n)\n\n;; Private helper functions\n(define-private (get-minimum-signatures (jurisdiction (string-ascii 64)))\n  (if (is-eq jurisdiction "FEDERAL") MIN_SIGNATURES_FEDERAL\n    (if (is-eq jurisdiction "STATE") MIN_SIGNATURES_STATE\n      MIN_SIGNATURES_LOCAL\n    )\n  )\n)\n\n(define-private (has-signed-petition (signer principal) (petition-id uint))\n  ;; Simplified check - in production would iterate through signatures\n  false\n)\n\n(define-private (update-official-metrics (token-id uint) (petition { title: (string-ascii 128), description: (string-ascii 512), category: (string-ascii 32), target-jurisdiction: (string-ascii 64), target-officials: (list 10 uint), created-by: principal, created-at: uint, signature-goal: uint, current-signatures: uint, deadline: uint, status: (string-ascii 20), response-required: bool, response-deadline: (optional uint) }) (current-time uint))\n  (let\n    (\n      (current-metrics (get-official-metrics token-id))\n      (new-total (+ (get total-petitions-received current-metrics) u1))\n      (new-responded (+ (get petitions-responded current-metrics) u1))\n      (response-time (- current-time (get created-at petition)))\n      (new-avg-time (/ (+ (* (get average-response-time current-metrics) (get petitions-responded current-metrics)) response-time) new-responded))\n    )\n    (map-set official-transparency-metrics\n      { token-id: token-id }\n      (merge current-metrics {\n        total-petitions-received: new-total,\n        petitions-responded: new-responded,\n        average-response-time: new-avg-time,\n        last-updated: current-time\n      })\n    )\n  )\n)\n\n(define-private (calculate-transparency-metrics (jurisdiction (string-ascii 64)))\n  {\n    total-officials: u10,    ;; Simplified - would count real officials\n    responsive-officials: u7,\n    average-response-rate: u70,\n    total-petitions: u25,\n    total-signatures: u15000\n  }\n)\n